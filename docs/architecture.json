      "REPLICATE_API_TOKEN",
      "OPENAI_VISION_MODEL (default: gpt-4o)",
      "OPENAI_MINI_MODEL (default: gpt-4o-mini)",
      "NEXT_PUBLIC_PRICE_REPORT_INR (default: 299)",
      "NEXT_PUBLIC_PRICE_REPORT_USD (default: 3.99)",
      "NEXT_PUBLIC_PRICE_STUDIO_PRO_INR (default: 999)",
      "NEXT_PUBLIC_PRICE_STUDIO_PRO_USD (default: 12.99)",
      "RAZORPAY_PLAN_ID_STUDIO_PRO_INR",
      "RAZORPAY_PLAN_ID_STUDIO_PRO_USD",
      "PAYMENT_TEST_ALLOW_IN_PROD (must be false in prod)",
      "SUPABASE_STORAGE_BUCKET (default: selfies)",
      "NEXT_PUBLIC_APP_NAME (default: Renovaara)"
    ]
  },

  "prompts": {
    "file": "src/prompts/index.ts",
    "key_builders": [
      { "fn": "buildColorAnalysisPrompt(opts?)", "description": "Dynamic color analysis prompt (canary color_v2_dominant active)" },
      { "fn": "buildSkinRoutinePrompt()", "description": "AM/PM routine generation prompt" },
      { "fn": "buildFeaturesPrompt()", "description": "Face features prompt" },
      { "fn": "buildGlassesPrompt()", "description": "Glasses recommendation prompt" },
      { "fn": "SYSTEM_BASE", "description": "Global system preamble for all pipeline calls" },
      { "fn": "COMPILE_PROMPT", "description": "Final summary compilation prompt" },
      { "fn": "SKIN_VISION_PROMPT", "description": "Skin type vision analysis prompt" }
    ],
    "canary_stages": ["face_shape", "color_analysis", "skin_analysis", "features", "glasses", "hairstyle", "summary"],
    "active_variant": "color_v2_dominant (color_v1 disabled at weight 0)"
  },

  "testing": {
    "framework": "Vitest",
    "config": "vitest.config.ts",
    "environment": "node",
    "settings": { "isolate": true, "alias": "@ → ./src" },
    "unit_tests": [
      "src/lib/ai/confidence.test.ts",
      "src/lib/ai/contracts.test.ts",
      "src/lib/ai/pipeline.test.ts"
    ],
    "eval_pipeline": {
      "script": "scripts/eval-pipeline.ts",
      "command": "npm run eval",
      "note": "Calls real OpenAI — never run in CI without API key",
      "fixtures": "scripts/eval-fixtures/<stage>/<id>.json"
    }
  },

  "design_system": {
    "docs": "design-system/renovaara/MASTER.md",
    "page_overrides": "design-system/pages/[page-name].md",
    "tailwind_config": "tailwind.config.ts",
    "color_aliases": [
      { "tailwind": "terracotta", "actual": "#EC4899 (pink)", "canonical": "chrome" },
      { "tailwind": "olive", "actual": "#8B5CF6 (violet)", "canonical": "iris" },
      { "tailwind": "obsidian", "actual": "#FDF2F8 (soft pink bg)", "canonical": "obsidian" }
    ],
    "note": "Legacy aliases kept for backward compat — new code should use canonical names"
  },

  "security": {
    "last_audited": "2025-05",
    "rules": [
      "createSupabaseAdminClient() bypasses RLS — always validate user_id ownership explicitly",
      "selfies bucket must remain private",
      "INTERNAL_API_SECRET must be ≥16 chars",
      "HMAC comparisons use timingSafeEqual — never ===",
      "Currency from server geo headers only",
      "Site URL must be set to prod domain in Supabase Auth settings",
      "PAYMENT_TEST_ALLOW_IN_PROD must be false in production",
      "ADMIN_EMAIL_ALLOWLIST — never hardcode emails in source; .env.example uses a placeholder",
      "skinContext fields (ageRange, selfReportedFeeling, primaryConcern) stripped of control chars and capped at 100 chars before LLM injection",
      "trigger-visuals timingSafeEqual: buffers padded to equal length before comparison to prevent secret-length side-channel"
    ],
    "fixes_applied": [
      { "issue": "skinContext prompt injection", "severity": "MEDIUM", "file": "src/app/api/analyze/route.ts", "fix": "Control chars stripped, fields capped 100 chars" },
      { "issue": "trigger-visuals timing side-channel", "severity": "LOW", "file": "src/app/api/internal/trigger-visuals/route.ts", "fix": "Buffers padded to max length before timingSafeEqual" },
      { "issue": ".env.example real personal email", "severity": "LOW", "file": ".env.example", "fix": "Replaced with admin@yourdomain.com placeholder" },
      { "issue": "onSubscribed not wired (Studio Pro no-op)", "severity": "BUG", "file": "src/components/report/ReportLayout.tsx", "fix": "onSubscribed navigates to /success?type=studio_pro" }
    ]
  }
}
