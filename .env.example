# ----------------------------------------------------------
# StyleAI — Environment Variables Template
# Copy to `.env.local` and fill in your secrets.
# ----------------------------------------------------------

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=StyleAI

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=selfies

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini

# --- Replicate (hairstyle inpainting — primary try-on path) ---
# Get your token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# --- AWS Rekognition ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret

# --- Razorpay ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_PAID_PRICE_USD=9.99
NEXT_PUBLIC_PAID_PRICE_INR=829

# --- Feature flags ---
NEXT_PUBLIC_ENABLE_PDF=true

# --- Access control ---
# Comma-separated list of admin emails that should bypass paid gating.
ADMIN_EMAIL_ALLOWLIST=Paraspahwa5@gmail.com
